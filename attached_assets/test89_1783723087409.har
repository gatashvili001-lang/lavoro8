            "size": 4525,
            "mimeType": "text/html",
            "text": "<!DOCTYPE html>\n<html lang=\"it\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1\" />\n\n    <title>Lavoro8.com — Lavoro e Offerte di Lavoro in Italia | Work in Europe</title>\n    <meta name=\"description\" content=\"Lavoro8.com: trova lavoro subito in Italia e in Europa. Migliaia di offerte di lavoro per magazzino, logistica, rider, ristorazione, hotel. Candidatura gratuita in 1 click. Find work fast across Europe.\" />\n    <meta name=\"keywords\" content=\"lavoro, work, offerte lavoro, lavoro Italia, cerco lavoro, trovo lavoro, lavoro subito, lavoro magazzino, lavoro logistica, lavoro ristorante, lavoro hotel, rider lavoro, lavoro operaio, annunci lavoro, bacheca lavoro, find work, jobs in Italy, jobs in Europe\" />\n    <meta name=\"robots\" content=\"index, follow\" />\n    <meta name=\"author\" content=\"lavoro8.com\" />\n    <link rel=\"manifest\" href=\"/manifest.json\" />\n    <meta name=\"theme-color\" content=\"#1d4ed8\" />\n    <meta name=\"mobile-web-app-capable\" content=\"yes\" />\n    <meta name=\"apple-mobile-web-app-capable\" content=\"yes\" />\n    <meta name=\"apple-mobile-web-app-status-bar-style\" content=\"default\" />\n    <meta name=\"apple-mobile-web-app-title\" content=\"lavoro8.com\" />\n    <link rel=\"canonical\" href=\"https://lavoro8.com/\" />\n\n    <meta property=\"og:type\" content=\"website\" />\n    <meta property=\"og:url\" content=\"https://lavoro8.com/\" />\n    <meta property=\"og:title\" content=\"Lavoro8.com — Lavoro e Offerte di Lavoro in Italia | Work in Europe\" />\n    <meta property=\"og:description\" content=\"Trova lavoro subito in Italia e in Europa. Magazzino, logistica, ristorazione, hotel e molto altro. Candidatura gratuita.\" />\n    <meta property=\"og:image\" content=\"https://lavoro8.com/opengraph.jpg\" />\n    <meta property=\"og:locale\" content=\"it_IT\" />\n    <meta property=\"og:site_name\" content=\"lavoro8.com\" />\n\n    <meta name=\"twitter:card\" content=\"summary_large_image\" />\n    <meta name=\"twitter:title\" content=\"lavoro8.com — Offerte di Lavoro in Italia\" />\n    <meta name=\"twitter:description\" content=\"Trova lavoro in Italia in pochi secondi. Magazzino, logistica, ristorazione, hotel e molto altro.\" />\n    <meta name=\"twitter:image\" content=\"https://lavoro8.com/opengraph.jpg\" />\n\n    <link rel=\"icon\" type=\"image/svg+xml\" href=\"/favicon.svg\" />\n    <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n    <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n    <link href=\"https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400..800&family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n\n    <meta name=\"google-adsense-account\" content=\"ca-pub-4337524588583476\">\n    <script async src=\"https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4337524588583476\" crossorigin=\"anonymous\"></script>\n\n    <!-- Google tag (gtag.js) -->\n    <script async src=\"https://www.googletagmanager.com/gtag/js?id=G-T53ZWKWYT5\"></script>\n    <script>\n      window.dataLayer = window.dataLayer || [];\n      function gtag(){dataLayer.push(arguments);}\n      gtag('js', new Date());\n\n      gtag('config', 'AW-18310856760');\n      gtag('config', 'G-T53ZWKWYT5');\n    </script>\n\n    <script type=\"application/ld+json\">\n    {\n      \"@context\": \"https://schema.org\",\n      \"@type\": \"WebSite\",\n      \"name\": \"lavoro8.com\",\n      \"url\": \"https://lavoro8.com/\",\n      \"description\": \"Lavoro e offerte di lavoro in Italia e in Europa per operai, magazzinieri, rider, camerieri e addetti hotel. Find work across Europe.\",\n      \"potentialAction\": {\n        \"@type\": \"SearchAction\",\n        \"target\": {\n          \"@type\": \"EntryPoint\",\n          \"urlTemplate\": \"https://lavoro8.com/jobs?search={search_ter